# Supabase (required for bookings, contact form, testimonials, social
# tracking, and the /admin dashboard). Without these the public site still
# runs on placeholder content, and /admin shows a setup notice.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL, used for metadata/Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: transactional email via Resend (booking confirmations, admin
# notifications, contact form alerts). Booking/contact still succeed without
# these — email sending is silently skipped.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
